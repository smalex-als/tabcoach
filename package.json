{
  "name": "tabcoach",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Local TypeScript server plus Chrome extension for duplicate tab detection and repo registry export.",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "check": "tsc --noEmit -p tsconfig.json"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "openai": "^6.6.0",
    "ts-node": "^10.9.2"
  },
  "devDependencies": {
    "@types/node": "^24.5.2",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2"
  }
}
